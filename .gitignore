cat > .gitignore <<'EOF'
# ── Dependency folders ─────────────────────────────────────
backend/node_modules/
frontend/node_modules/

# ── Angular build artefacts ─────────────────────────────────
frontend/dist/
frontend/.angular/

# ── OS / editor artefacts ───────────────────────────────────
.DS_Store
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment / secret files ───────────────────────────────
.env
*.env
*.local

# ── Miscellaneous ─────────────────────────────────────────────
/coverage
/tmp
*.tgz
